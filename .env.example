# API Spring Boot (Pajeu-Ticket-API)
NEXT_PUBLIC_API_URL=http://localhost:8080

# Login social (Google)
# Console: https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=

# Login social (Facebook)
# Developers: https://developers.facebook.com/apps
NEXT_PUBLIC_FACEBOOK_APP_ID=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# URL pública do site (links de recuperação de senha)
FRONTEND_URL=http://localhost:3000

# E-mail (SMTP) — opcional em dev; sem SMTP o link aparece no log da API
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@cinesaojose.com

# Stitch (https://stitch.withgoogle.com → perfil → Stitch Settings → API Key)
STITCH_API_KEY=

# Alternativa OAuth (requer token válido em ~/.gemini/oauth_creds.json)
# GOOGLE_CLOUD_PROJECT=seu-projeto-gcp
